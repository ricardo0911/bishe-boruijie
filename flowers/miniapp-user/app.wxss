page {
  background:
    radial-gradient(circle at 8% 0%, #ffe9f1 0%, rgba(255, 233, 241, 0) 44%),
    radial-gradient(circle at 94% 0%, #fff1de 0%, rgba(255, 241, 222, 0) 38%),
    #fff8f6;
  color: #352b33;
  font-size: 32rpx;
  line-height: 1.6;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei UI", sans-serif;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #eedde4;
  border-radius: 26rpx;
  box-shadow: 0 14rpx 36rpx rgba(154, 75, 102, 0.1);
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #352b33;
}

.section-sub {
  font-size: 26rpx;
  color: #8a7782;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  color: #bf4d68;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 700;
}

.price-value {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.btn-primary {
  min-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #df6f8b 0%, #bf4d68 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  min-height: 88rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e8c8d3;
  color: #bf4d68;
  background: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

button::after {
  border: none;
}

.empty-wrap {
  margin-top: 24rpx;
  padding: 44rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx dashed #e6d2da;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  color: #8a7782;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
