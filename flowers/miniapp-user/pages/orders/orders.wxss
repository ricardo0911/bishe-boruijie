/* 标签栏 */
.tab-scroll {
  white-space: nowrap;
  background: rgba(255, 255, 255, 0.88);
  padding: 16rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #eedbe3;
}

.tab-wrap {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx;
}

.tab-pill {
  min-height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ead3dc;
  background: #fffdfd;
  color: #675761;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.tab-pill-active {
  color: #ffffff;
  border-color: transparent;
  background: linear-gradient(135deg, #d56f8d 0%, #bb5476 100%);
  font-weight: 600;
}

.orders-banner {
  margin: 16rpx 24rpx 4rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #ecd4de;
  background:
    radial-gradient(circle at 0% 0%, rgba(244, 190, 207, 0.34) 0%, rgba(244, 190, 207, 0) 44%),
    linear-gradient(140deg, #fffefe 0%, #fff7fa 62%, #fffef8 100%);
}

.orders-banner-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #382d37;
}

.orders-banner-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #7f6d79;
}

/* 订单卡片 */
.order-card {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 26rpx rgba(154, 75, 102, 0.12);
  border: 2rpx solid #f1e3ea;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.order-head-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.order-no {
  font-size: 24rpx;
  color: #675761;
  font-weight: 500;
}

.order-time {
  font-size: 22rpx;
  color: #9a8b94;
}

/* 状态标签 */
.status-pill {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  font-weight: 500;
}

.status-default {
  color: #62555f;
  background: #f2eef1;
}

.status-success {
  color: #2f8f63;
  background: #e8f6ef;
}

.status-danger {
  color: #cb4456;
  background: #fdecef;
}

.status-warning {
  color: #d48806;
  background: #fff7e6;
}

.status-info {
  color: #2f8f63;
  background: #e8f6ef;
}

/* 商品列表 */
.order-goods-list {
  border-top: 2rpx solid #f3e5ec;
  border-bottom: 2rpx solid #f3e5ec;
  padding: 20rpx 0;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #fef7fa;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.goods-title {
  font-size: 28rpx;
  color: #352b33;
  font-weight: 500;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-price {
  font-size: 28rpx;
  color: #bf4d68;
  font-weight: 600;
}

.goods-qty {
  font-size: 24rpx;
  color: #9a8b94;
}

.more-goods {
  text-align: center;
  padding-top: 12rpx;
}

.more-text {
  font-size: 24rpx;
  color: #9a8b94;
}

/* 订单底部 */
.order-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  margin-bottom: 20rpx;
}

.order-total {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.total-label {
  font-size: 26rpx;
  color: #675761;
}

.total-symbol {
  font-size: 24rpx;
  color: #352b33;
  font-weight: 600;
}

.total-amount {
  font-size: 36rpx;
  color: #3a2f39;
  font-weight: 700;
}

/* 倒计时 */
.countdown-wrap {
  display: flex;
  align-items: center;
}

.countdown-text {
  font-size: 24rpx;
  color: #d48806;
  font-weight: 500;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f3e5ec;
}

.action-btn {
  min-height: 64rpx;
  min-width: 160rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0;
  line-height: 1;
}

/* 加载更多 */
.load-more-wrap {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #9a8b94;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  color: #352b33;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9a8b94;
  margin-bottom: 40rpx;
}

.empty-btn {
  min-width: 240rpx;
  min-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0e6ea;
  border-top-color: #bf4d68;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9a8b94;
}
