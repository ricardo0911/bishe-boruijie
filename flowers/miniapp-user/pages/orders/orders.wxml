<view class="container safe-bottom">
  <!-- 状态筛选标签 -->
  <scroll-view class="tab-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
    <view class="tab-wrap">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-pill {{currentStatus===item.key?'tab-pill-active':''}}"
        data-key="{{item.key}}"
        bindtap="onTapTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="orders-banner card">
    <text class="orders-banner-title">花之都 · 订单花笺</text>
    <text class="orders-banner-sub">从下单到签收，陪你追踪每一束花的旅程。</text>
  </view>

  <!-- 订单列表 -->
  <view wx:if="{{orders.length>0}}">
    <view
      class="order-card card"
      wx:for="{{orders}}"
      wx:key="orderNo"
      data-no="{{item.orderNo}}"
      bindtap="onTapOrder"
    >
      <!-- 订单头部 -->
      <view class="order-head">
        <view class="order-head-left">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <text class="status-pill {{item.statusClass}}">{{item.statusLabel}}</text>
      </view>

      <!-- 商品列表（最多显示2个） -->
      <view class="order-goods-list">
        <view class="goods-item" wx:for="{{item.items}}" wx:key="productId" wx:for-item="goods">
          <image
            class="goods-image"
            src="{{goods.coverImage || '/assets/placeholder.png'}}"
            mode="aspectFill"
          />
          <view class="goods-info">
            <text class="goods-title">{{goods.productTitle}}</text>
            <view class="goods-meta">
              <text class="goods-price">¥{{goods.unitPrice}}</text>
              <text class="goods-qty">x{{goods.quantity}}</text>
            </view>
          </view>
        </view>
        <!-- 更多商品提示 -->
        <view class="more-goods" wx:if="{{item.items.length > 2}}">
          <text class="more-text">共{{item.itemCount}}件商品</text>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-foot">
        <view class="order-total">
          <text class="total-label">合计：</text>
          <text class="total-symbol">¥</text>
          <text class="total-amount">{{item.totalAmount}}</text>
        </view>

        <!-- 待支付倒计时 -->
        <view class="countdown-wrap" wx:if="{{item.status === 'PENDING_PAY' && countdownMap[item.orderNo]}}">
          <text class="countdown-text">剩余 {{countdownMap[item.orderNo]}}</text>
        </view>
      </view>

      <!-- 操作按钮区 -->
      <view class="order-actions">
        <!-- 待支付状态 -->
        <block wx:if="{{item.status === 'PENDING_PAY'}}">
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            data-amount="{{item.totalAmount}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onPay"
          >
            立即支付
          </button>
          <button
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onCancel"
          >
            取消订单
          </button>
        </block>

        <!-- 已支付/待发货状态 -->
        <block wx:if="{{item.status === 'PAID' || item.status === 'CONFIRMED'}}">
          <button
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onCancel"
          >
            申请退款
          </button>
        </block>

        <!-- 已发货状态 -->
        <block wx:if="{{item.status === 'SHIPPED'}}">
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onConfirmReceive"
          >
            确认收货
          </button>
          <button class="btn-secondary action-btn" data-no="{{item.orderNo}}" bindtap="onTapOrder">
            查看物流
          </button>
        </block>

        <!-- 已完成状态 -->
        <block wx:if="{{item.status === 'COMPLETED'}}">
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            bindtap="onBuyAgain"
          >
            再次购买
          </button>
          <button class="btn-secondary action-btn" data-no="{{item.orderNo}}" bindtap="onTapOrder">
            查看详情
          </button>
        </block>

        <!-- 已取消/已退款状态 -->
        <block wx:if="{{item.status === 'CANCELLED' || item.status === 'REFUNDED'}}">
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            bindtap="onBuyAgain"
          >
            再次购买
          </button>
          <button class="btn-secondary action-btn" data-no="{{item.orderNo}}" bindtap="onTapOrder">
            查看详情
          </button>
        </block>
      </view>
    </view>

  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading}}" class="empty-wrap">
    <image class="empty-icon" src="/assets/empty.png" mode="aspectFit" />
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">去选购心仪的鲜花吧</text>
    <button class="btn-primary empty-btn" bindtap="onBuyAgain">去逛逛</button>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
