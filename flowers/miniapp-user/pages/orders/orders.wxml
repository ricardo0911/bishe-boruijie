<view class="container safe-bottom">
  <scroll-view class="tab-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
    <view class="tab-wrap">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-pill {{currentStatus === item.key ? 'tab-pill-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTapTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="orders-banner card">
    <text class="orders-banner-title">订单列表</text>
    <text class="orders-banner-sub">实时查看鲜花订单状态，支付、退款、收货都可以在这里完成。</text>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载订单...</text>
  </view>

  <view wx:elif="{{orders.length > 0}}">
    <view
      class="order-card card"
      wx:for="{{orders}}"
      wx:key="orderNo"
      data-no="{{item.orderNo}}"
      bindtap="onTapOrder"
    >
      <view class="order-head">
        <view class="order-head-left">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <text class="status-pill {{item.statusClass}}">{{item.statusLabel}}</text>
      </view>

      <view class="order-goods-list">
        <view class="goods-item" wx:for="{{item.items}}" wx:key="productId" wx:for-item="goods">
          <image
            class="goods-image"
            src="{{goods.coverImage || '/assets/placeholder.png'}}"
            mode="aspectFill"
          />
          <view class="goods-info">
            <text class="goods-title">{{goods.productTitle || goods.productName || goods.title}}</text>
            <view class="goods-meta">
              <text class="goods-price">¥{{goods.unitPrice}}</text>
              <text class="goods-qty">x{{goods.quantity}}</text>
            </view>
          </view>
        </view>
        <view class="more-goods" wx:if="{{item.itemCount > 2}}">
          <text class="more-text">共 {{item.itemCount}} 件商品</text>
        </view>
      </view>

      <view class="order-foot">
        <view class="order-total">
          <text class="total-label">合计：</text>
          <text class="total-symbol">¥</text>
          <text class="total-amount">{{item.totalAmount}}</text>
        </view>

        <view class="countdown-wrap" wx:if="{{item.status === 'PENDING_PAY' && countdownMap[item.orderNo]}}">
          <text class="countdown-text">剩余支付时间：{{countdownMap[item.orderNo]}}</text>
        </view>
      </view>

      <view wx:if="{{item.status === 'COMPLETED' && item.reviewableCount > 0}}" class="review-summary">{{item.reviewSummary}}</view>

      <view class="order-actions">
        <block wx:if="{{item.status === 'PENDING_PAY'}}">
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            data-amount="{{item.totalAmount}}"
            loading="{{actionOrderNo === item.orderNo}}"
            bindtap="onPay"
          >
            立即支付
          </button>
          <button
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo === item.orderNo}}"
            bindtap="onCancel"
          >
            取消订单
          </button>
        </block>

        <block wx:elif="{{item.status === 'PAID'}}">
          <button
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            bindtap="onTapOrder"
          >
            查看详情
          </button>
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo === item.orderNo}}"
            bindtap="onRefund"
          >
            申请退款
          </button>
        </block>

        <block wx:elif="{{item.status === 'CONFIRMED' || item.status === 'SHIPPED'}}">
          <button
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            bindtap="onViewLogistics"
          >
            查看物流
          </button>
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo === item.orderNo}}"
            bindtap="onConfirmReceive"
          >
            确认收货
          </button>
        </block>

        <block wx:elif="{{item.status === 'COMPLETED'}}">
          <button
            class="btn-secondary action-btn {{item.reviewButtonClass}}"
            data-no="{{item.orderNo}}"
            bindtap="onGoReview"
          >
            {{item.reviewActionText}}
          </button>
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo === item.orderNo}}"
            bindtap="onRefund"
          >
            申请退款
          </button>
        </block>

        <block wx:else>
          <button
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            bindtap="onTapOrder"
          >
            查看详情
          </button>
          <button
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            bindtap="onBuyAgain"
          >
            再来一单
          </button>
        </block>
      </view>
    </view>
  </view>

  <view wx:else class="empty-wrap">
    <image class="empty-icon" src="/assets/empty.png" mode="aspectFit" />
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">去首页挑选一束鲜花，完成下单后会显示在这里。</text>
    <button class="btn-primary empty-btn" bindtap="onBuyAgain">去逛逛</button>
  </view>

  <view wx:if="{{refundPopupVisible}}" class="refund-dialog-mask" bindtap="onCloseRefundPopup">
    <view class="refund-dialog" catchtap="noop" catchtouchmove="noop">
      <view class="refund-dialog-header">
        <text class="refund-dialog-title">申请退款</text>
        <text class="refund-dialog-subtitle">请填写退款理由，提交后将进入商家审核。</text>
      </view>
      <textarea
        class="refund-dialog-textarea"
        value="{{refundReason}}"
        placeholder="请填写退款理由"
        maxlength="500"
        auto-height
        focus="{{refundPopupVisible}}"
        bindinput="onInputRefundReason"
      />
      <view class="refund-dialog-footer">
        <button class="refund-dialog-btn refund-dialog-cancel" bindtap="onCloseRefundPopup" disabled="{{actionOrderNo === refundOrderNo}}">取消</button>
        <button class="refund-dialog-btn refund-dialog-confirm" bindtap="onSubmitRefund" loading="{{actionOrderNo === refundOrderNo}}">提交申请</button>
      </view>
    </view>
  </view>
</view>
