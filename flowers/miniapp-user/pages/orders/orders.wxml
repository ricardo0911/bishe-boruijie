<view class="container safe-bottom">
  <scroll-view class="tab-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
    <view class="tab-wrap">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-pill {{currentStatus===item.key?'tab-pill-active':''}}"
        data-key="{{item.key}}"
        bindtap="onTapTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{orders.length>0}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="orderNo">
      <view class="order-head">
        <text class="order-no">{{item.orderNo}}</text>
        <text class="status-pill {{item.statusClass}}">{{item.statusLabel}}</text>
      </view>

      <view class="line-item" wx:for="{{item.items}}" wx:key="index">
        <view class="line-cover">花</view>
        <view class="line-main">
          <text class="line-title">{{item.productTitle}}</text>
          <view class="line-bottom">
            <view class="price-row">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.unitPrice}}</text>
            </view>
            <text class="line-qty">x{{item.quantity}}</text>
          </view>
        </view>
      </view>

      <view class="order-foot">
        <text class="total-text">合计：¥{{item.totalAmount}}</text>
        <view class="action-group">
          <button
            wx:if="{{item.status==='LOCKED'}}"
            class="btn-primary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onPay"
          >
            模拟支付
          </button>
          <button
            wx:if="{{item.status==='LOCKED'}}"
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onCancel"
          >
            取消
          </button>
          <button
            wx:if="{{item.status==='PAID'}}"
            class="btn-secondary action-btn"
            data-no="{{item.orderNo}}"
            loading="{{actionOrderNo===item.orderNo}}"
            bindtap="onCancel"
          >
            申请退款
          </button>
        </view>
      </view>
    </view>
  </view>

  <view wx:elif="{{!loading}}" class="empty-wrap">
    <text class="empty-title">暂无订单</text>
  </view>
</view>
