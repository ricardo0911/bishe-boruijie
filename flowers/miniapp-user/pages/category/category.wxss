.search-wrap {
  min-height: 88rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
}

.search-input {
  width: 100%;
  height: 60rpx;
  font-size: 28rpx;
  color: #352b33;
}

.tab-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.tab-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 2rpx 2rpx 6rpx;
}

.tab-pill {
  min-height: 80rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #eadde3;
  background: #ffffff;
  color: #675761;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.tab-pill-active {
  color: #ffffff;
  border-color: transparent;
  background: linear-gradient(135deg, #df6f8b 0%, #bf4d68 100%);
}

.product-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.product-card {
  overflow: hidden;
}

.product-cover {
  height: 200rpx;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #bf4d68;
  border: 2rpx solid #efcfda;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.product-content {
  padding: 16rpx 14rpx 18rpx;
}

.product-title {
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #352b33;
  min-height: 74rpx;
}
