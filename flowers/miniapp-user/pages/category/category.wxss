/* 页面容器 */
.container {
  display: flex;
  height: 100vh;
  background:
    radial-gradient(circle at 4% 0%, rgba(243, 190, 206, 0.3) 0%, rgba(243, 190, 206, 0) 42%),
    #fff8f6;
}

/* 左侧分类导航 */
.category-sidebar {
  width: 180rpx;
  height: 100%;
  background: rgba(255, 255, 255, 0.86);
  border-right: 1rpx solid #ecd9e0;
}

.category-item {
  position: relative;
  padding: 30rpx 20rpx;
  text-align: center;
  transition: all 0.2s ease;
  border-bottom: 1rpx solid rgba(236, 217, 224, 0.5);
}

.category-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 0;
  background: linear-gradient(180deg, #d56f8d 0%, #bb5476 100%);
  transition: height 0.2s ease;
}

.category-item-active {
  background-color: rgba(255, 255, 255, 0.95);
}

.category-item-active::before {
  height: 40rpx;
}

.category-name {
  font-size: 26rpx;
  color: #6e5d68;
  line-height: 1.4;
}

.category-item-active .category-name {
  color: #bb5476;
  font-weight: 600;
}

.category-empty {
  padding: 40rpx 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

/* 右侧商品区域 */
.product-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.75);
}

.merchant-bar {
  margin: 18rpx 20rpx 0;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  border: 2rpx solid #ecd6de;
  background:
    radial-gradient(circle at 0% 0%, rgba(244, 191, 208, 0.35) 0%, rgba(244, 191, 208, 0) 40%),
    linear-gradient(145deg, #fffefe 0%, #fff6fa 60%, #fffdf8 100%);
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.merchant-bar-label {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #bf4d68;
  background: #ffeaf1;
  margin-top: 2rpx;
}

.merchant-bar-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.merchant-bar-name {
  font-size: 26rpx;
  font-weight: 650;
  color: #3a2f39;
}

.merchant-bar-address {
  font-size: 22rpx;
  color: #7f6c78;
}

.merchant-bar-arrow {
  font-size: 34rpx;
  font-weight: 700;
  color: #bb5476;
  line-height: 1;
  padding-top: 2rpx;
}

.category-brand {
  margin: 18rpx 20rpx 0;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  border: 2rpx solid #ecd6de;
  background:
    radial-gradient(circle at 0% 0%, rgba(244, 191, 208, 0.35) 0%, rgba(244, 191, 208, 0) 40%),
    linear-gradient(145deg, #fffefe 0%, #fff6fa 60%, #fffdf8 100%);
}

.category-brand-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3a2f39;
}

.category-brand-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7f6c78;
}

/* 分类标题 */
.category-header {
  padding: 24rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-bottom: 1rpx solid #f0e3e9;
}

.category-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3a2f39;
}

/* 商品滚动区域 */
.product-scroll {
  flex: 1;
  height: 0;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

/* 商品卡片 */
.product-card {
  background-color: rgba(255, 255, 255, 0.92);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(154, 75, 102, 0.12);
  transition: transform 0.2s ease;
  border: 2rpx solid #f1e4ea;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image-wrap {
  position: relative;
  width: 100%;
  height: 240rpx;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 60rpx;
  color: #df6f8b;
  opacity: 0.5;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-merchant {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d7b86;
}

.product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #bf4d68;
  font-weight: 600;
}

.price-value {
  font-size: 32rpx;
  color: #bf4d68;
  font-weight: 700;
}

.sales-text {
  font-size: 22rpx;
  color: #999999;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-icon-text {
  color: #c06383;
  font-weight: 700;
}

.empty-title {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #999999;
}

/* 加载更多 */
.load-more {
  padding: 30rpx 0;
  text-align: center;
}

.load-text {
  font-size: 24rpx;
  color: #999999;
}

.load-finish {
  color: #cccccc;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #bf4d68;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666666;
}
