<view class="container">
  <!-- 左侧分类导航 -->
  <scroll-view class="category-sidebar" scroll-y="true" show-scrollbar="false">
    <view
      class="category-item {{currentCategoryId === item.id ? 'category-item-active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onTapCategory"
    >
      <text class="category-name">{{item.name}}</text>
    </view>
    <view wx:if="{{categories.length === 0 && !initialLoading}}" class="category-empty">
      <text>暂无分类</text>
    </view>
  </scroll-view>

  <!-- 右侧商品区域 -->
  <view class="product-area">

    <!-- 门店选择 -->
    <view class="merchant-bar" bindtap="onPickMerchant">
      <text class="merchant-bar-label">花店</text>
      <view class="merchant-bar-main">
        <text class="merchant-bar-name">{{selectedMerchantName}}</text>
        <text wx:if="{{selectedMerchantAddress}}" class="merchant-bar-address">{{selectedMerchantAddress}}</text>
      </view>
      <text class="merchant-bar-arrow">›</text>
    </view>

    <!-- 分类标题 -->
    <view class="category-header">
      <text class="category-title">{{currentCategoryName}}</text>
    </view>

    <!-- 商品列表 -->
    <scroll-view class="product-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
      <!-- 商品网格 -->
      <view wx:if="{{products.length > 0}}" class="product-grid">
        <view
          class="product-card"
          wx:for="{{products}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onTapProduct"
        >
          <view class="product-image-wrap">
            <image
              wx:if="{{item.coverImage}}"
              class="product-image"
              src="{{item.coverImage}}"
              mode="aspectFill"
              lazy-load="true"
            />
            <view wx:else class="product-placeholder">
              <text class="placeholder-text">花</text>
            </view>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.title}}</text>
            <view class="product-meta">
              <view class="price-wrap">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.unitPrice}}</text>
              </view>
              <text wx:if="{{item.sales > 0}}" class="sales-text">已售 {{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!initialLoading && products.length === 0}}" class="empty-wrap">
        <view class="empty-icon">
          <text class="empty-icon-text">花</text>
        </view>
        <text class="empty-title">暂无商品</text>
        <text class="empty-subtitle">该分类下暂时没有商品</text>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{products.length > 0}}" class="load-more">
        <text wx:if="{{loading && !initialLoading}}" class="load-text">加载中...</text>
        <text wx:elif="{{!hasMore}}" class="load-text load-finish">没有更多了</text>
        <text wx:else class="load-text">上拉加载更多</text>
      </view>
    </scroll-view>
  </view>

  <!-- 初始加载状态 -->
  <view wx:if="{{initialLoading}}" class="loading-mask">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
