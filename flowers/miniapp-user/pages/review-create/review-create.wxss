.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f8f5f6;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 20rpx;
  border: 2rpx solid #f0e1e7;
  box-shadow: 0 12rpx 28rpx rgba(154, 75, 102, 0.1);
}

.hero,
.tips,
.review-card {
  margin-bottom: 20rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #382d37;
}

.hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8e7480;
}

.link-btn {
  margin: 0;
  min-width: 170rpx;
  min-height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #fff7fa;
  color: #bb5476;
  border: 2rpx solid #efd8e1;
  font-size: 24rpx;
}

.tips {
  padding: 24rpx 28rpx;
  font-size: 24rpx;
  color: #7b6670;
  line-height: 1.7;
}

.review-card {
  padding: 28rpx;
}

.goods-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #fff7fa;
  flex-shrink: 0;
}

.goods-main {
  flex: 1;
  min-width: 0;
}

.goods-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #352b33;
  line-height: 1.5;
}

.goods-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8f7a84;
}

.reviewed-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef8f1;
  color: #2f8f63;
  font-size: 22rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 24rpx;
}

.score-label {
  font-size: 26rpx;
  color: #675761;
}

.star-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.star {
  font-size: 40rpx;
  color: #d8c3cc;
}

.star-active {
  color: #f5b400;
}

.content-box {
  width: 100%;
  min-height: 180rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fbf7f9;
  border: 2rpx solid #f0e1e7;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #352b33;
}

.review-content {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #fbf7f9;
  font-size: 26rpx;
  color: #4b3c45;
  line-height: 1.7;
}

.review-time {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9a8b94;
}

.submit-btn {
  margin-top: 24rpx;
  min-height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d56f8d 0%, #bb5476 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-wrap,
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 40rpx;
}

.empty-title,
.loading-text {
  font-size: 30rpx;
  color: #352b33;
  font-weight: 600;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #9a8b94;
  text-align: center;
  line-height: 1.7;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0e6ea;
  border-top-color: #bf4d68;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.image-item {
  position: relative;
}

.preview-image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 16rpx;
  background: #fff7fa;
}

.remove-image {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(53, 43, 51, 0.78);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-btn {
  margin-top: 20rpx;
  min-height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  background: #fff7fa;
  color: #bb5476;
  border: 2rpx solid #efd8e1;
  font-size: 25rpx;
}

.reply-box {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #fdf5f8;
  border: 2rpx solid #f0dfe6;
}

.reply-title {
  display: block;
  font-size: 24rpx;
  color: #bb5476;
  font-weight: 600;
}

.reply-content {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4b3c45;
  line-height: 1.7;
}

.reply-time {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9a8b94;
}