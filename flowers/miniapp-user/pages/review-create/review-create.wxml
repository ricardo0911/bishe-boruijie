<view class="page safe-bottom">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载可评价商品...</text>
  </view>

  <block wx:elif="{{items.length > 0}}">
    <view class="hero card">
      <view>
        <text class="hero-title">订单评价</text>
        <text class="hero-sub">订单号：{{orderNo}}</text>
      </view>
      <button class="link-btn" bindtap="onGoOrderDetail">查看订单</button>
    </view>

    <view class="tips card">
      <text>完成后可为订单中的每件商品分别评分，支持上传最多 3 张实拍图。</text>
    </view>

    <view class="review-card card" wx:for="{{items}}" wx:key="productId" wx:for-item="goods">
      <view class="goods-row">
        <image class="goods-image" src="{{goods.coverImage || '/assets/placeholder.png'}}" mode="aspectFill" />
        <view class="goods-main">
          <text class="goods-title">{{goods.productTitle}}</text>
          <text class="goods-meta">¥{{goods.unitPrice}} × {{goods.quantity}}</text>
        </view>
        <text wx:if="{{goods.reviewed}}" class="reviewed-tag">已评价</text>
      </view>

      <view class="score-row">
        <text class="score-label">评分</text>
        <view class="star-wrap">
          <text
            wx:for="{{starOptions}}"
            wx:key="*this"
            wx:for-item="star"
            class="star {{star <= goods.score ? 'star-active' : ''}}"
            data-product-id="{{goods.productId}}"
            data-score="{{star}}"
            bindtap="onTapScore"
          >★</text>
        </view>
      </view>

      <textarea
        wx:if="{{!goods.reviewed}}"
        class="content-box"
        placeholder="写下你对花束品质、包装或配送体验的感受（选填）"
        maxlength="200"
        value="{{goods.content}}"
        data-product-id="{{goods.productId}}"
        bindinput="onInputContent"
      />

      <view wx:if="{{goods.images && goods.images.length > 0}}" class="image-list">
        <view class="image-item" wx:for="{{goods.images}}" wx:key="index" wx:for-item="img" wx:for-index="imgIndex">
          <image class="preview-image" src="{{img}}" mode="aspectFill" data-product-id="{{goods.productId}}" data-index="{{imgIndex}}" bindtap="onPreviewImages" />
          <view wx:if="{{!goods.reviewed}}" class="remove-image" data-product-id="{{goods.productId}}" data-index="{{imgIndex}}" bindtap="onRemoveImage">×</view>
        </view>
      </view>

      <button
        wx:if="{{!goods.reviewed && goods.images.length < 3}}"
        class="image-btn"
        data-product-id="{{goods.productId}}"
        loading="{{uploadingProductId === goods.productId}}"
        bindtap="onChooseImages"
      >上传图片</button>

      <view wx:if="{{goods.reviewed && goods.content}}" class="review-content">{{goods.content}}</view>
      <text wx:if="{{goods.reviewed && goods.createTime}}" class="review-time">{{goods.createTime}}</text>

      <view wx:if="{{goods.reply}}" class="reply-box">
        <text class="reply-title">商家回复</text>
        <text class="reply-content">{{goods.reply}}</text>
        <text wx:if="{{goods.replyTime}}" class="reply-time">{{goods.replyTime}}</text>
      </view>

      <button
        wx:if="{{!goods.reviewed}}"
        class="submit-btn"
        data-product-id="{{goods.productId}}"
        loading="{{submittingProductId === goods.productId}}"
        bindtap="onSubmitReview"
      >提交评价</button>
    </view>
  </block>

  <view wx:else class="empty-wrap">
    <text class="empty-title">暂无可评价商品</text>
    <text class="empty-desc">该订单中的商品可能已全部评价，或者订单状态暂未完成。</text>
    <button class="submit-btn" bindtap="onGoOrderDetail">返回订单</button>
  </view>
</view>