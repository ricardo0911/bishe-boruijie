<view class="page-shell">
  <view class="hero-card">
    <text class="hero-title">注册账号</text>
    <text class="hero-desc">注册后可同步个人资料、购物车、地址、收藏和订单数据。</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">账号</text>
      <input class="input" placeholder="4-32 位字母数字或下划线" value="{{account}}" bindinput="onInputAccount" maxlength="32" />
    </view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{name}}" bindinput="onInputName" maxlength="32" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="选填，用于收货联系" value="{{phone}}" bindinput="onInputPhone" maxlength="11" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" password placeholder="请输入 6-32 位密码" value="{{password}}" bindinput="onInputPassword" maxlength="32" />
    </view>
    <view class="form-item no-border">
      <text class="label">确认密码</text>
      <input class="input" password placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onInputConfirmPassword" maxlength="32" />
    </view>
  </view>

  <button class="primary-btn" loading="{{submitting}}" bindtap="onSubmit">注册并登录</button>
</view>
