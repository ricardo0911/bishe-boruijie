.page-shell {
  min-height: 100vh;
  padding: 48rpx 28rpx 80rpx;
  background: linear-gradient(180deg, #fff7f4 0%, #fffdfc 100%);
}

.hero-card,
.form-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(191, 77, 104, 0.08);
}

.hero-card {
  padding: 40rpx 36rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2e1f27;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7c6470;
}

.form-card {
  padding: 0 28rpx;
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f4e4ea;
}

.form-item.no-border {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #8f7d88;
  margin-bottom: 14rpx;
}

.input {
  font-size: 30rpx;
  color: #2e1f27;
}

.primary-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  background: linear-gradient(135deg, #cf5f7f 0%, #bf4d68 100%);
  color: #fff;
}
