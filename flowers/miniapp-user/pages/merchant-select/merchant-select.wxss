.header-card {
  padding: 26rpx 24rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #352b33;
}

.header-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a7782;
}

.option-card {
  margin-bottom: 14rpx;
  padding: 22rpx 22rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.option-card.active {
  border-color: #d56f8d;
  box-shadow: 0 18rpx 46rpx rgba(187, 84, 118, 0.16);
}

.option-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.option-name {
  font-size: 30rpx;
  font-weight: 650;
  color: #352b33;
}

.option-sub {
  font-size: 24rpx;
  color: #8a7782;
  line-height: 1.5;
}

.option-sub.phone {
  color: #bb5476;
}

.option-check {
  font-size: 34rpx;
  font-weight: 800;
  color: #bb5476;
  line-height: 1;
  padding-top: 2rpx;
}

.list {
  padding-bottom: 24rpx;
}

