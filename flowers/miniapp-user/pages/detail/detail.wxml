<view class="container safe-bottom detail-page">
  <view wx:if="{{product}}">
    <view class="hero card">
      <image wx:if="{{product.coverImage}}" class="hero-image" src="{{product.coverImage}}" mode="aspectFill" />
      <view wx:else class="hero-badge">{{product.categoryShort}}</view>
    </view>

    <view class="card info-card">
      <view class="price-row">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{product.unitPrice}}</text>
      </view>
      <text class="title">{{product.title}}</text>
      <text class="desc">{{product.description}}</text>
      <view class="tag-row">
        <text class="tag">{{product.typeLabel}}</text>
        <text class="tag">{{product.categoryLabel}}</text>
      </view>
    </view>

    <view wx:if="{{product.bomItems.length>0}}" class="card bom-card">
      <text class="bom-title">花材清单</text>
      <view class="bom-row" wx:for="{{product.bomItems}}" wx:key="flowerName">
        <text class="bom-name">{{item.flowerName}}</text>
        <text class="bom-value">x{{item.dosage}}  ¥{{item.subtotal}}</text>
      </view>
      <view class="bom-row total-row">
        <text class="bom-name">包装费 + 配送费</text>
        <text class="bom-value">¥{{product.packagingFee}} + ¥{{product.deliveryFee}}</text>
      </view>
    </view>

    <view class="review-head">
      <text class="section-title">用户评价</text>
      <text class="section-sub">{{reviews.length}} 条</text>
    </view>
    <view wx:if="{{reviews.length>0}}" class="card review-card">
      <view class="review-item" wx:for="{{reviews}}" wx:key="id">
        <view class="review-top">
          <text class="review-user">{{item.userName}}</text>
          <text class="review-score">{{item.score}} / 5</text>
        </view>
        <text class="review-content">{{item.content || '用户未填写评价内容'}}</text>
      </view>
    </view>
    <view wx:else class="empty-wrap">
      <text class="empty-title">暂无评价</text>
    </view>
  </view>

  <view wx:else class="empty-wrap">
    <text class="empty-title">商品加载中...</text>
  </view>

  <view class="action-bar card">
    <view class="go-cart" bindtap="onGoCart">
      <view class="go-cart-badge">购</view>
      <text class="go-cart-text">购物车</text>
    </view>
    <button class="btn-secondary action-btn" bindtap="onAddCart" loading="{{cartLoading}}">加入购物车</button>
    <button class="btn-primary action-btn" bindtap="onBuyNow">立即购买</button>
  </view>
</view>
