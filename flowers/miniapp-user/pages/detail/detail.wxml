<view class="container safe-bottom detail-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{product}}" class="detail-content">
    <view class="swiper-wrap">
      <swiper
        class="product-swiper"
        indicator-dots="{{product.images.length > 1}}"
        autoplay="{{true}}"
        interval="3000"
        duration="300"
        circular="{{true}}"
        bindchange="onSwiperChange"
        current="{{swiperCurrent}}"
      >
        <swiper-item wx:for="{{product.images}}" wx:key="index">
          <image class="swiper-image" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewImage" />
        </swiper-item>
        <swiper-item wx:if="{{product.images.length === 0}}">
          <view class="swiper-placeholder">
            <text class="placeholder-text">{{product.categoryShort}}</text>
          </view>
        </swiper-item>
      </swiper>
      <view wx:if="{{product.images.length > 1}}" class="swiper-indicator">
        <text class="indicator-text">{{swiperCurrent + 1}} / {{product.images.length}}</text>
      </view>
    </view>

    <view class="content-wrap">
      <view class="card info-card">
        <view class="title-row">
          <text class="title">{{product.title}}</text>
          <button class="share-button" open-type="share" bindtap="onShare">
            <text class="share-icon">↗</text>
            <text class="share-text">分享</text>
          </button>
        </view>

        <view class="price-meta-row">
          <view class="price-row">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{product.unitPrice}}</text>
          </view>
          <view class="sales-info">
            <text class="sales-text">已售 {{product.sales}}</text>
            <text class="stock-text">库存 {{product.stock}}</text>
          </view>
        </view>

        <text class="desc">{{product.description || '暂无描述'}}</text>

        <view class="tag-row">
          <text class="tag">{{product.typeLabel}}</text>
          <text class="tag">{{product.categoryLabel}}</text>
        </view>
      </view>

      <view class="card service-strip">
        <view class="service-item">
          <text class="service-dot"></text>
          <text class="service-text">花材新鲜</text>
        </view>
        <view class="service-item">
          <text class="service-dot"></text>
          <text class="service-text">同城速配</text>
        </view>
        <view class="service-item">
          <text class="service-dot"></text>
          <text class="service-text">支持贺卡</text>
        </view>
      </view>

      <view class="card spec-entry" bindtap="showSpecPopup" data-type="cart">
        <text class="spec-label">规格</text>
        <view class="spec-main">
          <text class="spec-value">{{selectedSpec ? selectedSpec.name : '请选择规格'}}</text>
          <text class="spec-count">数量 {{quantity}}</text>
        </view>
        <text class="spec-arrow">›</text>
      </view>

      <view wx:if="{{product.bomItems.length > 0}}" class="card bom-card">
        <view class="section-head">
          <text class="section-title">花材清单</text>
        </view>
        <view class="bom-row" wx:for="{{product.bomItems}}" wx:key="flowerName">
          <text class="bom-name">{{item.flowerName}}</text>
          <text class="bom-value">x{{item.dosage}} ¥{{item.subtotal}}</text>
        </view>
        <view class="bom-row total-row">
          <text class="bom-name">包装费 + 配送费</text>
          <text class="bom-value">¥{{product.packagingFee}} + ¥{{product.deliveryFee}}</text>
        </view>
      </view>

      <view class="review-section">
        <view class="review-head">
          <text class="section-title">用户评价</text>
          <text class="section-sub">{{reviews.length}} 条</text>
        </view>
        <view wx:if="{{reviews.length > 0}}" class="card review-card">
          <view class="review-item" wx:for="{{reviews}}" wx:key="id">
            <view class="review-top">
              <view class="review-user-wrap">
                <image wx:if="{{item.avatar}}" class="review-avatar" src="{{item.avatar}}" mode="aspectFill" />
                <view wx:else class="review-avatar-default">{{item.userName && item.userName[0] ? item.userName[0] : '匿'}}</view>
                <text class="review-user">{{item.userName || '匿名用户'}}</text>
              </view>
              <view class="review-score-wrap">
                <text class="review-stars">{{item.score >= 1 ? '★' : '☆'}}{{item.score >= 2 ? '★' : '☆'}}{{item.score >= 3 ? '★' : '☆'}}{{item.score >= 4 ? '★' : '☆'}}{{item.score >= 5 ? '★' : '☆'}}</text>
                <text class="review-score">{{item.score}}分</text>
              </view>
            </view>
            <text class="review-content">{{item.content || '用户未填写评价内容'}}</text>
            <view wx:if="{{item.images && item.images.length > 0}}" class="review-images">
              <image wx:for="{{item.images}}" wx:for-item="img" wx:key="index" class="review-img" src="{{img}}" mode="aspectFill" />
            </view>
            <text wx:if="{{item.createTime}}" class="review-time">{{item.createTime}}</text>
          </view>
          <view wx:if="{{hasMoreReviews}}" class="load-more" bindtap="loadMoreReviews">
            <text class="load-more-text">加载更多</text>
          </view>
        </view>
        <view wx:else class="empty-wrap">
          <text class="empty-title">暂无评价</text>
          <text class="empty-desc">快来购买，成为第一个评价的人吧</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-wrap">
    <text class="empty-title">商品不存在或已下架</text>
    <button class="btn-primary" bindtap="onGoHome">返回首页</button>
  </view>

  <view class="action-bar" wx:if="{{product}}">
    <view class="action-left">
      <view class="action-icon-btn" bindtap="onGoHome">
        <text class="action-icon">⌂</text>
        <text class="action-icon-text">首页</text>
      </view>
      <view class="action-icon-btn" bindtap="onToggleFavorite">
        <text class="action-icon {{isFavorite ? 'favorite-active' : ''}}">{{isFavorite ? '♥' : '♡'}}</text>
        <text class="action-icon-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-icon-btn" bindtap="onGoCart">
        <text class="action-icon">🛒</text>
        <text class="action-icon-text">购物车</text>
      </view>
    </view>
    <view class="action-right">
      <button class="btn-secondary action-btn" bindtap="onAddCartClick">加入购物车</button>
      <button class="btn-primary action-btn" bindtap="onBuyNowClick">立即购买</button>
    </view>
  </view>

  <view class="spec-popup {{showSpecPopup ? 'show' : ''}}" wx:if="{{product}}">
    <view class="spec-popup-mask" bindtap="closeSpecPopup"></view>
    <view class="spec-popup-content">
      <view class="spec-popup-header">
        <image wx:if="{{product.coverImage}}" class="spec-popup-image" src="{{product.coverImage}}" mode="aspectFill" />
        <view wx:else class="spec-popup-image-placeholder">{{product.categoryShort}}</view>
        <view class="spec-popup-info">
          <text class="spec-popup-price">¥{{selectedSpec ? selectedSpec.price : product.unitPrice}}</text>
          <text class="spec-popup-stock">库存 {{selectedSpec ? selectedSpec.stock : product.stock}} 件</text>
          <text class="spec-popup-selected">已选：{{selectedSpec ? selectedSpec.name : '请选择规格'}}</text>
        </view>
        <view class="spec-popup-close" bindtap="closeSpecPopup">×</view>
      </view>

      <scroll-view class="spec-popup-body" scroll-y="true">
        <view class="spec-section">
          <text class="spec-section-title">规格</text>
          <view class="spec-list">
            <view
              wx:for="{{product.specs}}"
              wx:key="id"
              class="spec-item {{selectedSpec && selectedSpec.id === item.id ? 'active' : ''}} {{item.stock <= 0 ? 'disabled' : ''}}"
              data-spec="{{item}}"
              bindtap="onSelectSpec"
            >
              {{item.name}}
            </view>
          </view>
        </view>

        <view class="spec-section">
          <text class="spec-section-title">数量</text>
          <view class="quantity-selector">
            <view class="quantity-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="onQuantityMinus">-</view>
            <input class="quantity-input" type="number" value="{{quantity}}" bindblur="onQuantityInput" />
            <view class="quantity-btn {{quantity >= (selectedSpec ? selectedSpec.stock : product.stock) ? 'disabled' : ''}}" bindtap="onQuantityPlus">+</view>
          </view>
        </view>
      </scroll-view>

      <view class="spec-popup-footer">
        <button wx:if="{{actionType === 'cart'}}" class="btn-secondary action-btn-full" bindtap="onAddCart" loading="{{cartLoading}}">加入购物车</button>
        <button wx:elif="{{actionType === 'buy'}}" class="btn-primary action-btn-full" bindtap="onBuyNow">立即购买</button>
        <view wx:else class="spec-popup-btns">
          <button class="btn-secondary action-btn-half" bindtap="onAddCart" loading="{{cartLoading}}">加入购物车</button>
          <button class="btn-primary action-btn-half" bindtap="onBuyNow">立即购买</button>
        </view>
      </view>
    </view>
  </view>
</view>
