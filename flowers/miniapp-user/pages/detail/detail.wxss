.detail-page {
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
}

.hero {
  height: 360rpx;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-badge {
  width: 140rpx;
  height: 140rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #eecfda;
  color: #bf4d68;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 62rpx;
  font-weight: 700;
}

.info-card {
  margin-top: 14rpx;
  padding: 22rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #352b33;
  line-height: 1.35;
}

.desc {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #675761;
  line-height: 1.65;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tag {
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #ffeaf1;
  color: #bf4d68;
  font-size: 24rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
}

.bom-card {
  margin-top: 14rpx;
  padding: 20rpx;
}

.bom-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2830;
}

.bom-row {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #f0e6ea;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.bom-name {
  font-size: 27rpx;
  color: #433942;
}

.bom-value {
  font-size: 25rpx;
  color: #73656f;
}

.total-row .bom-name,
.total-row .bom-value {
  font-weight: 600;
}

.review-head {
  margin: 24rpx 2rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-card {
  padding: 0 20rpx;
}

.review-item {
  padding: 18rpx 0;
  border-top: 2rpx solid #f0e6ea;
}

.review-item:first-child {
  border-top: none;
}

.review-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2830;
}

.review-score {
  font-size: 24rpx;
  color: #bf4d68;
}

.review-content {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #675761;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  min-height: 114rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  z-index: 40;
}

.go-cart {
  width: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.go-cart-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #ffeaf1;
  color: #bf4d68;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.go-cart-text {
  font-size: 22rpx;
  color: #675761;
}

.action-btn {
  flex: 1;
}
