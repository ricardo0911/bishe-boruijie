<view class="container safe-bottom profile-page">
  <view wx:if="{{loading}}" class="card loading-card">
    <view class="loading-dot"></view>
    <text class="loading-text">{{i18n.loading}}</text>
  </view>

  <view class="card hero-card">
    <view class="hero-glow hero-glow-a"></view>
    <view class="hero-glow hero-glow-b"></view>

    <view class="hero-top">
      <view class="avatar-wrap">
        <view class="avatar">{{userInitial}}</view>
        <text class="member-pill" data-action="member" bindtap="onTapAction">{{member.levelName}}</text>
      </view>

      <view class="hero-info">
        <view class="name-row">
          <text class="user-name">{{user.name}}</text>
          <text class="copy-name" bindtap="onCopyUserName">{{i18n.copyName}}</text>
        </view>

        <block wx:if="{{user.account}}">
          <text class="user-phone">{{i18n.accountPrefix}} {{user.account}}</text>
        </block>
        <block wx:else>
          <text class="user-phone">{{i18n.noAccount}}</text>
        </block>

        <text class="sync-text">{{i18n.syncedPrefix}} {{syncText}}</text>
      </view>
    </view>

    <view class="hero-metrics">
      <view class="metric-item" data-action="orders_all" bindtap="onTapAction">
        <text class="metric-value">{{stats.orderTotal}}</text>
        <text class="metric-label">{{i18n.ordersAll}}</text>
      </view>
      <view class="metric-item" data-action="orders_pending" bindtap="onTapAction">
        <text class="metric-value">{{stats.pendingPay}}</text>
        <text class="metric-label">{{i18n.ordersPending}}</text>
      </view>
      <view class="metric-item" data-action="orders_shipped" bindtap="onTapAction">
        <text class="metric-value">{{stats.shipped}}</text>
        <text class="metric-label">{{i18n.ordersShipped}}</text>
      </view>
      <view class="metric-item" data-action="cart" bindtap="onTapAction">
        <text class="metric-value">{{stats.cartItems}}</text>
        <text class="metric-label">{{i18n.cartItems}}</text>
      </view>
    </view>
  </view>

  <view class="card growth-card" data-action="member" bindtap="onTapAction">
    <view class="growth-head">
      <text class="growth-title">{{i18n.growthTitle}}</text>
      <view class="growth-head-side">
        <text class="growth-points">{{i18n.pointsPrefix}} {{user.points}}</text>
        <text class="growth-arrow">></text>
      </view>
    </view>
    <view class="growth-track">
      <view class="growth-fill" style="width: {{member.progress}}%;"></view>
    </view>
    <text class="growth-tip">{{member.toNextText}}</text>
  </view>

  <view class="card menu-card">
    <view class="menu-item" data-action="favorite" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.favoriteTitle}}</text>
        <text class="menu-desc">{{i18n.favoriteDesc}}</text>
      </view>
      <view class="menu-side">
        <text class="menu-badge">{{stats.favoriteCount}} {{i18n.favoriteUnit}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" data-action="reviews" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.reviewTitle}}</text>
        <text class="menu-desc">{{i18n.reviewDesc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" data-action="feedback" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.feedbackTitle}}</text>
        <text class="menu-desc">{{i18n.feedbackDesc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" data-action="refund" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.refundTitle}}</text>
        <text class="menu-desc">{{i18n.refundDesc}}</text>
      </view>
      <view class="menu-side">
        <text class="menu-badge">{{stats.refundCount}} 单</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" data-action="address" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.addressTitle}}</text>
        <text class="menu-desc">{{i18n.addressDesc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" data-action="change_password" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.passwordTitle}}</text>
        <text class="menu-desc">{{i18n.passwordDesc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" data-action="service" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.serviceTitle}}</text>
        <text class="menu-desc">{{i18n.serviceDesc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item logout-item no-border" data-action="logout" bindtap="onTapAction">
      <view class="menu-main">
        <text class="menu-title">{{i18n.logoutTitle}}</text>
        <text class="menu-desc">{{i18n.logoutDesc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
