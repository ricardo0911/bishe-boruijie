<view class="container favorites-page safe-bottom">
  <view class="card intro-card">
    <text class="section-title">收藏记录</text>
    <text class="section-sub intro-sub">可在商品详情收藏喜欢的鲜花，方便后续快速查看。</text>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{favorites.length === 0}}" class="empty-wrap">
    <text class="empty-title">还没有收藏商品</text>
    <text class="empty-desc">可在商品详情收藏</text>
    <button class="btn-primary explore-btn" bindtap="onGoShopping">去逛逛</button>
  </view>

  <view wx:else class="favorites-list">
    <view
      wx:for="{{favorites}}"
      wx:key="productId"
      class="favorite-card card"
      data-id="{{item.productId}}"
      bindtap="onTapFavorite"
    >
      <view class="cover-wrap">
        <image wx:if="{{item.coverImage}}" class="cover-image" src="{{item.coverImage}}" mode="aspectFill" />
        <view wx:else class="cover-placeholder">花</view>
      </view>
      <view class="favorite-body">
        <text class="favorite-title">{{item.title}}</text>
        <text class="favorite-time">收藏时间：{{item.collectedAt || '刚刚'}}</text>
        <view class="favorite-actions">
          <view class="detail-btn">查看详情</view>
          <view class="remove-btn" catchtap="onRemoveFavorite" data-id="{{item.productId}}">
            {{removingId === item.productId ? '处理中...' : '取消收藏'}}
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
