<view class="page-shell">
  <view class="hero-card">
    <text class="hero-title">修改密码</text>
    <text class="hero-desc">修改后下次登录请使用新密码。</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">原密码</text>
      <input class="input" password placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onInputOldPassword" maxlength="32" />
    </view>
    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" password placeholder="请输入 6-32 位新密码" value="{{newPassword}}" bindinput="onInputNewPassword" maxlength="32" />
    </view>
    <view class="form-item no-border">
      <text class="label">确认新密码</text>
      <input class="input" password placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onInputConfirmPassword" maxlength="32" />
    </view>
  </view>

  <button class="primary-btn" loading="{{submitting}}" bindtap="onSubmit">确认修改</button>
</view>
