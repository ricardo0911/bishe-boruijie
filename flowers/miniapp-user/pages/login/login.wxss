.page-shell {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
  padding: 56rpx 28rpx 88rpx;
  background: linear-gradient(180deg, #fff3f6 0%, #fffaf8 48%, #fff8ef 100%);
}

.bg-scene {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-orb {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.9;
}

.orb-left {
  top: -120rpx;
  left: -90rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(238, 154, 178, 0.42) 0%, rgba(238, 154, 178, 0) 72%);
}

.orb-right {
  top: 140rpx;
  right: -110rpx;
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(213, 111, 141, 0.3) 0%, rgba(213, 111, 141, 0) 74%);
}

.orb-bottom {
  bottom: -150rpx;
  left: 50%;
  margin-left: -260rpx;
  width: 520rpx;
  height: 520rpx;
  background: radial-gradient(circle, rgba(255, 216, 191, 0.44) 0%, rgba(255, 216, 191, 0) 72%);
}

.bg-petal {
  position: absolute;
  border-radius: 70% 30% 68% 32% / 32% 66% 34% 68%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 226, 235, 0.42) 100%);
  box-shadow: 0 18rpx 40rpx rgba(191, 77, 104, 0.08);
  transform: rotate(-18deg);
}

.petal-a {
  top: 220rpx;
  left: 34rpx;
  width: 128rpx;
  height: 84rpx;
}

.petal-b {
  top: 104rpx;
  right: 74rpx;
  width: 96rpx;
  height: 64rpx;
  transform: rotate(22deg);
}

.petal-c {
  right: 46rpx;
  bottom: 260rpx;
  width: 142rpx;
  height: 90rpx;
  transform: rotate(-32deg);
}

.hero-card,
.form-card {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.65);
  border-radius: 28rpx;
  box-shadow: 0 20rpx 44rpx rgba(191, 77, 104, 0.1);
}

.hero-card {
  padding: 42rpx 36rpx;
  margin-top: 72rpx;
  margin-bottom: 24rpx;
}

.hero-tag {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(213, 111, 141, 0.12);
  color: #bf4d68;
  font-size: 20rpx;
  letter-spacing: 3rpx;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2e1f27;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7c6470;
}

.form-card {
  z-index: 1;
  padding: 0 28rpx;
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f4e4ea;
}

.form-item.no-border {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #8f7d88;
  margin-bottom: 14rpx;
}

.input {
  font-size: 30rpx;
  color: #2e1f27;
}

.primary-btn,
.ghost-btn {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #cf5f7f 0%, #bf4d68 100%);
  color: #fff;
  box-shadow: 0 20rpx 34rpx rgba(191, 77, 104, 0.2);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #bf4d68;
  border: 1rpx solid #f0cad6;
}
