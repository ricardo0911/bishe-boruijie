.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8f6 0%, #fff3f0 100%);
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 20rpx 40rpx rgba(203, 68, 86, 0.08);
  margin-bottom: 24rpx;
}

.hero-card {
  background: linear-gradient(135deg, #fff6f4 0%, #ffe7ec 100%);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #3b2330;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7e6170;
}

.hero-status {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4caf50;
  margin-right: 12rpx;
}

.status-text {
  font-size: 24rpx;
  color: #5f4b57;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  padding: 0;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #cb4456 0%, #e56b87 100%);
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.secondary-btn {
  color: #cb4456;
  background: #fff1f3;
}

.tip-box {
  margin-top: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.7);
}

.tip-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #82626e;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #34212b;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #92808b;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f2e7ea;
  gap: 20rpx;
}

.no-border {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #7e6874;
}

.info-side {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex: 1;
}

.multi-line {
  align-items: flex-start;
}

.info-value {
  font-size: 26rpx;
  color: #34212b;
  text-align: right;
}

.address-text {
  line-height: 1.7;
}

.inline-link {
  font-size: 24rpx;
  color: #cb4456;
}


.faq-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2e7ea;
}

.faq-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.faq-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.faq-question {
  flex: 1;
  font-size: 28rpx;
  color: #34212b;
  font-weight: 600;
}

.faq-arrow {
  font-size: 24rpx;
  color: #cb4456;
}

.faq-answer {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.9;
  color: #7f6974;
}

.loading-mask {
  display: flex;
  justify-content: center;
  padding: 10rpx 0 24rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #8f7d88;
}
