.search-wrap {
  min-height: 92rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  border: 2rpx solid #edd3dd;
  background: linear-gradient(135deg, #fffefe 0%, #fff7fa 58%, #fffef8 100%);
}

.search-placeholder {
  font-size: 28rpx;
  color: #8a7581;
}

.merchant-pick {
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border: 2rpx solid #ecd6de;
  background: linear-gradient(135deg, #fffefe 0%, #fff6fa 58%, #fffef8 100%);
}

.merchant-pick-main {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.merchant-pick-label {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #bf4d68;
  background: #ffeaf1;
}

.merchant-pick-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.merchant-pick-name {
  font-size: 28rpx;
  font-weight: 650;
  color: #352b33;
}

.merchant-pick-address {
  font-size: 22rpx;
  color: #8a7581;
}

.merchant-pick-arrow {
  font-size: 34rpx;
  font-weight: 700;
  color: #bb5476;
  line-height: 1;
}

.brand-hero {
  margin-bottom: 16rpx;
  padding: 22rpx 22rpx 20rpx;
  border: 2rpx solid #ecd6de;
  background:
    radial-gradient(circle at 0% 0%, rgba(245, 186, 207, 0.35) 0%, rgba(245, 186, 207, 0) 42%),
    linear-gradient(140deg, #fffdfd 0%, #fff6fa 62%, #f8fff8 100%);
}

.brand-hero-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 14rpx;
}

.brand-cn {
  font-size: 44rpx;
  font-weight: 700;
  color: #352b33;
  letter-spacing: 4rpx;
}

.brand-en {
  font-size: 18rpx;
  color: #9d7386;
  letter-spacing: 1.2rpx;
}

.brand-slogan {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7d6874;
}

.brand-tags {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.brand-tag {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ebd0da;
  background: rgba(255, 255, 255, 0.8);
  color: #ba4f6f;
  font-size: 22rpx;
  display: flex;
  align-items: center;
}

.container {
  height: 100vh;
}

.hero-swiper {
  height: 300rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(154, 75, 102, 0.2);
}

.hero-item {
  height: 100%;
  position: relative;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 56rpx 36rpx;
  box-sizing: border-box;
  background: linear-gradient(to right, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 70%);
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  opacity: 0.95;
}

.category-grid {
  margin-top: 16rpx;
  padding: 18rpx 10rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
}

.category-item {
  min-height: 116rpx;
  padding: 10rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.category-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(140deg, #ffe7ef 0%, #fff2f6 100%);
  color: #bf4d68;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.category-label {
  font-size: 22rpx;
  color: #675761;
  line-height: 1.2;
  text-align: center;
}

.section-head {
  margin: 28rpx 2rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-action {
  font-size: 24rpx;
  color: #bf4d68;
}

.section-gap {
  margin-top: 26rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.product-card {
  overflow: hidden;
}

.product-cover {
  height: 200rpx;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #bf4d68;
  border: 2rpx solid #efcfda;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.product-content {
  padding: 16rpx 14rpx 18rpx;
}

.product-title {
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #352b33;
  min-height: 74rpx;
}

.product-merchant {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8d7b86;
}

.recent-sales {
  margin-top: 6rpx;
  display: inline-block;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #bf4d68;
  background: #ffeaf1;
}

.creative-card {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 2rpx solid #ebd4dd;
  background: linear-gradient(160deg, #fffefe 0%, #fff7f9 64%, #fffdf8 100%);
}

.creative-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.creative-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2830;
}

.creative-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #85717d;
}

.creative-refresh {
  min-width: 116rpx;
  min-height: 54rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e9ccd7;
  color: #bf4d68;
  background: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-row {
  margin-top: 16rpx;
  white-space: nowrap;
}

.chip-group {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 4rpx;
}

.scene-chip {
  min-width: 180rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  border: 2rpx solid #ecdbe3;
  background: #ffffff;
  box-sizing: border-box;
}

.scene-chip-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #403640;
}

.scene-chip-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #8d7a85;
}

.scene-chip-active {
  border-color: #df6f8b;
  background: linear-gradient(135deg, #fff1f5 0%, #fff9fb 100%);
}

.scene-chip-active .scene-chip-title {
  color: #bf4d68;
}

.budget-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.budget-pill {
  flex: 1;
  min-height: 54rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ead6de;
  background: #ffffff;
  color: #6f606a;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.budget-pill-active {
  border-color: #df6f8b;
  color: #bf4d68;
  background: #fff1f5;
  font-weight: 600;
}

.inspiration-slogan {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6f616b;
  line-height: 1.5;
}

.inspiration-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.inspiration-empty {
  margin-top: 14rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #e9d2dc;
  background: #fffdfd;
  color: #8f7a86;
  font-size: 23rpx;
  line-height: 1.5;
}

.inspiration-item {
  position: relative;
  display: flex;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  border: 2rpx solid #eedde4;
  background: #ffffff;
}

.inspiration-rank {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 78rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 0 16rpx 0 16rpx;
  background: #bf4d68;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inspiration-image,
.inspiration-badge {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.inspiration-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(150deg, #ffe7ee 0%, #fff5f8 100%);
  color: #bf4d68;
  font-size: 42rpx;
  font-weight: 700;
}

.inspiration-info {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.inspiration-title {
  font-size: 27rpx;
  color: #352b33;
  font-weight: 600;
}

.inspiration-merchant {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8d7b86;
}

.inspiration-reason {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #7f6f79;
}

.inspiration-bottom {
  margin-top: auto;
  padding-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.inspiration-sales {
  font-size: 21rpx;
  color: #a06f7f;
}

.inspiration-price {
  font-size: 31rpx;
  font-weight: 700;
  color: #bf4d68;
}

.gift-card {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(140deg, #fffaf2 0%, #fff4f7 100%);
  border: 2rpx dashed #ebd2db;
}

.gift-title {
  display: block;
  font-size: 24rpx;
  color: #8d6f7a;
}

.gift-message {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #423640;
}

.gift-copy {
  margin-top: 12rpx;
  height: 56rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dfbbc7;
  background: #ffffff;
  color: #bf4d68;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
