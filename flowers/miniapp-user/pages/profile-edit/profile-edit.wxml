<view class="container safe-bottom">
  <view class="card form-card">
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" value="{{name}}" placeholder="请输入昵称" bindinput="onInputName" />
    </view>
    <view class="form-item no-border">
      <text class="label">手机号</text>
      <input class="input" value="{{phone}}" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onInputPhone" />
    </view>
  </view>

  <button class="btn-primary save-btn" bindtap="onSave" loading="{{saving}}">保存资料</button>
</view>
