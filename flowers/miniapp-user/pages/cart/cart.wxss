.cart-page {
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
}

/* 购物车头部 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 12rpx 20rpx;
}

.cart-count {
  font-size: 26rpx;
  color: #8a7782;
}

.cart-action {
  font-size: 28rpx;
  color: #bf4d68;
  padding: 8rpx 16rpx;
}

/* 购物车项 */
.cart-item {
  margin-bottom: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 选择框 */
.item-checkbox {
  padding: 10rpx;
  margin: -10rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d4c4cb;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: linear-gradient(135deg, #df6f8b 0%, #bf4d68 100%);
  border-color: #bf4d68;
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 商品图片 */
.item-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  border: 2rpx solid #efdee5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.item-cover-image {
  width: 100%;
  height: 100%;
}

.item-cover-text {
  font-size: 54rpx;
  font-weight: 700;
  color: #bf4d68;
}

/* 商品信息 */
.item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 140rpx;
}

.item-title {
  font-size: 30rpx;
  color: #352b33;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-spec {
  font-size: 24rpx;
  color: #8a7782;
  margin-top: 6rpx;
}

.item-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

/* 数量控制 */
.qty-wrap {
  display: inline-flex;
  align-items: center;
  border: 2rpx solid #eadde3;
  border-radius: 999rpx;
  overflow: hidden;
}

.qty-btn {
  width: 56rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #675761;
  background: #fff;
}

.qty-btn:active {
  background: #f5f0f2;
}

.qty-num {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #352b33;
}

/* 删除按钮 */
.item-delete {
  margin-left: 10rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #df6f8b 0%, #bf4d68 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  border: 2rpx solid #efdee5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 80rpx;
}

.empty-title {
  font-size: 34rpx;
  color: #352b33;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #8a7782;
  margin-bottom: 40rpx;
}

.empty-btn {
  min-width: 240rpx;
}

/* 推荐商品 */
.recommend-section {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.recommend-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.recommend-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e6d2da, transparent);
}

.recommend-title {
  font-size: 30rpx;
  color: #8a7782;
  font-weight: 500;
}

.recommend-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.recommend-item {
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #eedde4;
  border-radius: 20rpx;
  overflow: hidden;
  padding: 12rpx;
}

.recommend-image-wrap {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: linear-gradient(155deg, #ffe7ee 0%, #fff9fb 62%, #fff5e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.recommend-image {
  width: 100%;
  height: 100%;
}

.recommend-image-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #bf4d68;
}

.recommend-item-title {
  font-size: 26rpx;
  color: #352b33;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  margin-bottom: 8rpx;
}

.recommend-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  color: #bf4d68;
}

.recommend-price .price-symbol {
  font-size: 22rpx;
  font-weight: 700;
}

.recommend-price .price-value {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  min-height: 116rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 20rpx;
  z-index: 40;
}

.checkout-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx;
  margin: -10rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #352b33;
}

.total-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: #8a7782;
}

.checkout-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkout-btn {
  min-width: 200rpx;
  min-height: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #df6f8b 0%, #bf4d68 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.checkout-btn::after {
  border: none;
}

.checkout-btn[disabled] {
  opacity: 0.6;
}

.batch-delete-btn {
  min-width: 160rpx;
  min-height: 80rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e8c8d3;
  color: #bf4d68;
  background: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.batch-delete-btn::after {
  border: none;
}
