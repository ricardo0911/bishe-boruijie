<view class="pay-page safe-bottom">
  <view class="pay-brand">
    <text class="pay-brand-title">微信支付</text>
    <text class="pay-brand-sub">安全支付保障</text>
  </view>

  <view class="card amount-card">
    <view class="amount-row">
      <text class="amount-symbol">¥</text>
      <text class="amount-value">{{amount}}</text>
    </view>
    <text class="amount-tip">待支付金额</text>
  </view>

  <view class="card order-card" wx:if="{{!loading}}">
    <view class="info-row">
      <text class="info-label">订单号</text>
      <text class="info-value">{{orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">商品</text>
      <text class="info-value text-ellipsis">{{productTitle}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">数量</text>
      <text class="info-value">{{itemCount}} 件</text>
    </view>
  </view>

  <view class="card method-card">
    <view class="method-left">
      <view class="wechat-icon">微</view>
      <view class="method-text">
        <text class="method-title">微信支付</text>
        <text class="method-desc">推荐，支持零钱/银行卡</text>
      </view>
    </view>
    <text class="method-tag">默认</text>
  </view>

  <view class="safe-tip">
    <text>支付即表示同意《支付服务协议》</text>
  </view>

  <view class="pay-actions">
    <button class="pay-btn" loading="{{submitting}}" bindtap="onConfirmPay">立即支付</button>
    <button class="cancel-btn" bindtap="onCancelPay">稍后支付</button>
  </view>
</view>
