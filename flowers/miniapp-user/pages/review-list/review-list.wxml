<view class="page safe-bottom">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载我的评价...</text>
  </view>

  <block wx:elif="{{reviews.length > 0}}">
    <view class="review-card card" wx:for="{{reviews}}" wx:key="id">
      <view class="goods-row">
        <image class="goods-image" src="{{item.productImage || '/assets/placeholder.png'}}" mode="aspectFill" />
        <view class="goods-main">
          <text class="goods-title">{{item.productTitle}}</text>
          <text class="goods-meta">订单号：{{item.orderNo}}</text>
        </view>
        <button class="mini-link" data-product-id="{{item.productId}}" bindtap="onGoProduct">看商品</button>
      </view>

      <view class="score-row">
        <text class="score-stars">{{item.score >= 1 ? '★' : '☆'}}{{item.score >= 2 ? '★' : '☆'}}{{item.score >= 3 ? '★' : '☆'}}{{item.score >= 4 ? '★' : '☆'}}{{item.score >= 5 ? '★' : '☆'}}</text>
        <text class="score-value">{{item.score}} 分</text>
      </view>

      <text class="content-text">{{item.content || '用户未填写评价内容'}}</text>

      <view wx:if="{{item.images && item.images.length > 0}}" class="image-list">
        <image
          wx:for="{{item.images}}"
          wx:key="index"
          wx:for-item="img"
          wx:for-index="imgIndex"
          class="preview-image"
          src="{{img}}"
          mode="aspectFill"
          data-review-id="{{item.id}}"
          data-index="{{imgIndex}}"
          bindtap="onPreviewImages"
        />
      </view>

      <view wx:if="{{item.reply}}" class="reply-box">
        <text class="reply-title">商家回复</text>
        <text class="reply-content">{{item.reply}}</text>
        <text wx:if="{{item.replyTime}}" class="reply-time">{{item.replyTime}}</text>
      </view>

      <view class="foot-row">
        <text class="time-text">{{item.createTime}}</text>
        <button class="mini-link" data-order-no="{{item.orderNo}}" bindtap="onGoOrder">看订单</button>
      </view>
    </view>
  </block>

  <view wx:else class="empty-wrap">
    <text class="empty-title">你还没有发表过评价</text>
    <text class="empty-desc">订单完成后，就可以在订单列表里点击“去评价”啦。</text>
  </view>
</view>