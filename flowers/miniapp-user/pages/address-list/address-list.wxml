<view class="container address-list-page">
  <view wx:if="{{source === 'local'}}" class="mode-tip">当前为本地地址簿模式</view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{addresses.length === 0}}" class="empty-wrap">
    <text class="empty-title">暂无收货地址</text>
    <text class="empty-desc">请添加收货地址</text>
    <button class="btn-primary add-btn" bindtap="onAddAddress">添加地址</button>
  </view>

  <view wx:else class="address-list">
    <view
      wx:for="{{addresses}}"
      wx:key="id"
      class="address-card {{item.isDefault ? 'address-default' : ''}}"
      data-address="{{item}}"
      bindtap="onSelectAddress"
    >
      <view class="address-header">
        <text class="address-name">{{item.receiverName || item.name}}</text>
        <text class="address-phone">{{item.receiverPhone || item.phone}}</text>
        <view wx:if="{{item.isDefault || item.is_default}}" class="default-tag">默认</view>
      </view>
      <view class="address-detail">{{item.fullAddress || item.full_address}}</view>
      <view class="address-actions">
        <view class="action-btn" catchtap="onEditAddress" data-id="{{item.id}}">
          <text class="action-text">编辑</text>
        </view>
        <view class="action-btn delete" catchtap="onDeleteAddress" data-id="{{item.id}}">
          <text class="action-text">删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="btn-primary add-btn" bindtap="onAddAddress">添加新地址</button>
  </view>
</view>
